{
  "name": "task-manager",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "build:web": "npm --workspace apps/web run build",
    "dev:api": "npm --workspace services/api run dev",
    "build:api": "npm --workspace services/api run build",
    "sam:local": "sam local start-api --template infra/template.yaml",
    "sam:build": "sam build --template-file infra/template.yaml",
    "sam:deploy": "sam deploy --guided --template-file infra/template.yaml",
    "backfill:lookups": "node scripts/backfill-lookups.js --table $TABLE_NAME"
  },
  "devDependencies": {
    "esbuild": "^0.27.3"
  }
}