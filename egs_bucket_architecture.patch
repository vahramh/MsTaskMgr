diff --git a/apps/web/src/features/tasks/useBucketTasks.ts b/apps/web/src/features/tasks/useBucketTasks.ts
new file mode 100644
--- /dev/null
+++ b/apps/web/src/features/tasks/useBucketTasks.ts
@@
 import { useEffect, useState } from "react";
 import { fetchBucket } from "./api";

 export function useBucketTasks(state: string) {

   const [tasks, setTasks] = useState<any[]>([]);

   useEffect(() => {
     fetchBucket(state).then(setTasks);
   }, [state]);

   return tasks;
 }

