+++ b/services/api/src/tasks/repo.ts
@@
 import { bucketKey, bucketSort } from "./keys";

 export function buildBucketIndex(task: any, sub: string) {
   if (task.entityType === "project") {
     return {};
   }

   return {
     GSI2PK: bucketKey(sub, task.state),
     GSI2SK: bucketSort(task.updatedAt, task.taskId)
   };
 }

diff --git a/services/api/src/handlers/tasks-buckets-list.ts b/services/api/src/handlers/tasks-buckets-list.ts
new file mode 100644
--- /dev/null
+++ b/services/api/src/handlers/tasks-buckets-list.ts
@@
 import { QueryCommand } from "@aws-sdk/lib-dynamodb";
 import { db } from "../db";

 export async function handler(event: any) {

   const state = event.pathParameters.state;
   const sub = event.requestContext.authorizer.jwt.claims.sub;

   const result = await db.send(new QueryCommand({
     TableName: process.env.TASKS_TABLE,
     IndexName: process.env.TASKS_GSI2,
     KeyConditionExpression: "GSI2PK = :pk",
     ExpressionAttributeValues: {
       ":pk": `USER#${sub}#STATE#${state}`
     }
   }));

   return {
     statusCode: 200,
     body: JSON.stringify(result.Items ?? [])
   };
 }

diff --git a/services/api/src/handlers/tasks-buckets-counts.ts b/services/api/src/handlers/tasks-buckets-counts.ts
new file mode 100644
--- /dev/null
+++ b/services/api/src/handlers/tasks-buckets-counts.ts
@@
 import { QueryCommand } from "@aws-sdk/lib-dynamodb";
 import { db } from "../db";

 const states = [
   "inbox",
   "next",
   "waiting",
   "scheduled",
   "someday",
   "reference",
   "completed"
 ];

 export async function handler(event: any) {

   const sub = event.requestContext.authorizer.jwt.claims.sub;

   const counts: any = {};

   for (const state of states) {

     const result = await db.send(new QueryCommand({
       TableName: process.env.TASKS_TABLE,
       IndexName: process.env.TASKS_GSI2,
       KeyConditionExpression: "GSI2PK = :pk",
       ExpressionAttributeValues: {
         ":pk": `USER#${sub}#STATE#${state}`
       },
       Select: "COUNT"
     }));

     counts[state] = result.Count ?? 0;
   }

   return {
     statusCode: 200,
     body: JSON.stringify(counts)
   };
 }

